<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="api-gym-app">
        <createTable tableName="gym">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="2" author="api-gym-app">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone_number" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="birthdate" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="gym_id" type="BIGINT">
                <constraints foreignKeyName="fk_users_gym" references="gym(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="api-gym-app">
        <createTable tableName="routines">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="day_of_week" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints foreignKeyName="fk_routines_user" references="users(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="api-gym-app">
        <createTable tableName="exercises">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="sets" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="repetitions" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="rest_time" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="weight_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="routine_id" type="BIGINT">
                <constraints foreignKeyName="fk_exercises_routine" references="routines(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>